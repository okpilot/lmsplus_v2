# Supabase — get these from supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx

# App URL — used for email redirects (password reset, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only — NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx

# Resend — transactional email (exam-code delivery). Server-only.
# API key from resend.com → API Keys. EMAIL_FROM must be an address on a
# verified sending domain (e.g. noreply@yourdomain.com). If RESEND_API_KEY is
# unset, the app logs emails to the console instead of sending (local dev).
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@yourdomain.com

# Supabase MCP — personal access token from supabase.com → Account → Access Tokens
# NOT the project API key — a personal token from your account settings
SUPABASE_ACCESS_TOKEN=sbp_xxxx
