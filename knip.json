{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "ignoreDependencies": ["zod"]
    },
    "apps/web": {
      "entry": [
        "app/**/page.tsx",
        "app/**/layout.tsx",
        "app/**/loading.tsx",
        "app/**/actions/*.ts",
        "app/**/route.ts",
        "app/globals.css",
        "scripts/*.ts"
      ],
      "project": ["**/*.{ts,tsx}"]
    },
    "packages/db": {
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignore": ["packages/typescript-config/**"]
}
